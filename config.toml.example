# Pika backend configuration example.
# Copy to config.toml (gitignored) and customise.
#
# config.toml is NOT the right place for credentials — use environment variables
# (or /etc/pika/pika.env in production). See README.md for details.
#
# Config file location can be overridden via:
# - PIKA_CONFIG_PATH environment variable (takes priority)
# - --config CLI argument
# - Default: ./config.toml

# Comma-separated list of absolute paths that Pika is allowed to use as project roots.
# Sessions can only be created under these directories.
project_root_paths = [
    "/home/youruser/projects/my-project",
    # "/srv/work/another-project",
]

# Address to bind the HTTP server to.
# Use 127.0.0.1 for local/tunnel deployments (recommended).
# Use 0.0.0.0 only if you need direct external access AND have other auth in front.
bind_address = "127.0.0.1"

# Port number.
# port = 7847

# Set to true ONLY for local development without authentication.
# NEVER set this in production.
debug_disable_auth = false

# Override CORS allowed origins (default: same-origin only).
# cors_allowed_origins = "https://your-domain.example"

# Whether to set Secure flag on session cookies.
# Set to false only for local HTTP development.
# session_cookie_secure = true

# Override the npx binary path (useful when Node is installed via nvm/fnm).
# pika_npx_path = "/home/youruser/.nvm/versions/node/v22.x.x/bin/npx"
