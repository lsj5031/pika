[Unit]
Description=Pika - AI Coding Companion
After=network.target cloudflared-pi.service

[Service]
Type=simple
# Run under the primary operator account so project roots and ~/.pika are accessible.
User=%i
# Keep group access to /etc/pika/*.toml and /etc/pika/pika.env (root:pika, 0640).
Group=pika
WorkingDirectory=/opt/pika
ExecStart=/opt/pika/target/release/pika --config /etc/pika/config.toml
Restart=always
RestartSec=5
Environment=PORT=7847
EnvironmentFile=-/etc/pika/pika.env
Environment=PATH=/usr/local/bin:/usr/bin:/bin

# Security hardening:
NoNewPrivileges=true
PrivateTmp=true
PrivateDevices=true
ProtectSystem=full
ProtectHome=false
ProtectControlGroups=true
ProtectKernelTunables=true
ProtectKernelModules=true
LockPersonality=true
MemoryDenyWriteExecute=true
ReadWritePaths=/var/lib/pika /run/pika
StateDirectory=pika
RuntimeDirectory=pika

[Install]
WantedBy=multi-user.target
